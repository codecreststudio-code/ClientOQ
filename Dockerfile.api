FROM node:24-alpine AS base
RUN npm install -g pnpm@10.33.2
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json .env ./
COPY packages/ ./packages/
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/

RUN pnpm install --frozen-lockfile

COPY apps/api/ ./apps/api/

RUN pnpm --filter @clientoq/database exec prisma generate
RUN pnpm --filter @clientoq/api build

EXPOSE 3001
CMD ["pnpm", "--filter", "@clientoq/api", "start"]
