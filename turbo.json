{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "JWT_SECRET",
    "PORT",
    "GOOGLE_CLIENT_ID",
    "NEXT_PUBLIC_API_URL",
    "NODE_ENV",
    "SENTRY_DSN",
    "SENTRY_AUTH_TOKEN",
    "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
    "SUPER_ADMIN_EMAILS",
    "CONTACT_TO_EMAIL",
    "RAZORPAY_WEBHOOK_SECRET",
    "NEXT_PUBLIC_ENABLE_MOCK_API"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "JWT_SECRET",
        "PORT",
        "GOOGLE_CLIENT_ID",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_GOOGLE_CLIENT_ID"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "dependsOn": ["build"]
    }
  }
}
